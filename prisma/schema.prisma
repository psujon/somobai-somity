generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("STAFF") // ADMIN, STAFF
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities ActivityLog[]
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   @default("LOGIN") // LOGIN, LOGOUT
  loginAt   DateTime @default(now())
  loginTime String?  // BD Time string
  ipAddress String?
  userAgent String?
}

model Member {
  id           String   @id @default(cuid())
  memberId     String   @unique // custom readable ID like M-001
  name         String
  phone        String   @unique
  email        String?
  nid          String?  @unique
  address      String?
  photo        String?
  type         String   @default("General") // General Member, Committee Member
  position     String   @default("Member") // President, Member, etc.
  status       String   @default("ACTIVE") // ACTIVE, SUSPENDED, CANCELLED
  joinDate     DateTime @default(now())
  
  savingsAccounts SavingsAccount[]
  loans          Loan[]
  monthlySavings MonthlySavingsSummary[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// মাসওয়াইজ সঞ্চয় সারসংক্ষেপ (সদস্য × বছর)
model MonthlySavingsSummary {
  id        String  @id @default(cuid())
  memberId  String
  member    Member  @relation(fields: [memberId], references: [id])
  year      Int     // যেমন: 2026

  jan  Float @default(0)  // জানুয়ারি
  feb  Float @default(0)  // ফেব্রুয়ারি
  mar  Float @default(0)  // মার্চ
  apr  Float @default(0)  // এপ্রিল
  may  Float @default(0)  // মে
  jun  Float @default(0)  // জুন
  jul  Float @default(0)  // জুলাই
  aug  Float @default(0)  // আগস্ট
  sep  Float @default(0)  // সেপ্টেম্বর
  oct  Float @default(0)  // অক্টোবর
  nov  Float @default(0)  // নভেম্বর
  dec  Float @default(0)  // ডিসেম্বর

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([memberId, year])  // একজন সদস্যের একটি বছরে একটিই রেকর্ড
}

model SavingsAccount {
  id           String   @id @default(cuid())
  accountNo    String   @unique
  memberId     String
  member       Member   @relation(fields: [memberId], references: [id])
  type         String   // GENERAL, DPS, FDR
  balance      Float    @default(0)
  interestRate Float    @default(0)
  status       String   @default("ACTIVE")
  openDate     DateTime @default(now())
  
  transactions SavingsTransaction[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SavingsTransaction {
  id               String         @id @default(cuid())
  savingsAccountId String
  savingsAccount   SavingsAccount @relation(fields: [savingsAccountId], references: [id])
  type             String         // DEPOSIT, WITHDRAWAL, INTEREST
  amount           Float
  date             DateTime       @default(now())
  transactionDate  DateTime?      // ট্রানজেকশন তারিখ (ফর্ম থেকে)
  depositMonth     String?        // ডিপোজিট মাস (YYYY-MM)
  voucherNo        String?        // ভাউচার নম্বর
  reference        String?        // পুরানো রেফারেন্স (backward compat)
  remarks          String?        // রিমার্কস
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Loan {
  id            String   @id @default(cuid())
  loanNo        String   @unique
  memberId      String
  member        Member   @relation(fields: [memberId], references: [id])
  amount        Float
  interestRate  Float
  totalPayable  Float
  totalPaid     Float    @default(0)
  status        String   @default("PENDING") // PENDING, APPROVED, ACTIVE, COMPLETED, DEFAULTED
  issueDate     DateTime?
  endDate       DateTime?
  
  installments  LoanInstallment[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LoanInstallment {
  id        String   @id @default(cuid())
  loanId    String
  loan      Loan     @relation(fields: [loanId], references: [id])
  amount    Float
  date      DateTime @default(now())
  status    String   @default("PAID") // PAID, LATE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Voucher {
  id          String   @id @default(cuid())
  voucherNo   String   @unique
  type        String   // INCOME, EXPENSE, INVESTMENT
  category    String   // Salary, Rent, Office Cost, Profit, etc.
  amount      Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Position {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MemberType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyProfile {
  id               String   @id @default("1")
  name             String?
  shortCode        String?
  logo             String?
  establishedYear  String?
  registrationNo   String?
  tinNo            String?
  vatNo            String?
  tradeLicenseNo   String?
  hotline          String?
  website          String?
  socialMediaLinks String?
  bankAccountNo    String?
  bankName         String?
  bankBranch       String?
  address          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
