generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("LOGIN")
  loginAt   DateTime @default(now())
  loginTime String?
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], map: "ActivityLog_userId_fkey")

  @@index([userId], map: "ActivityLog_userId_fkey")
  @@map("activitylog")
}

model CompanyProfile {
  id               String   @id @default("1")
  name             String?
  shortCode        String?
  logo             String?
  establishedYear  String?
  registrationNo   String?
  tinNo            String?
  vatNo            String?
  tradeLicenseNo   String?
  hotline          String?
  website          String?
  socialMediaLinks String?
  bankAccountNo    String?
  bankName         String?
  bankBranch       String?
  address          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("companyprofile")
}

model Loan {
  id              String            @id @default(cuid())
  loanNo          String            @unique(map: "Loan_loanNo_key")
  memberId        String
  amount          Float
  interestRate    Float
  totalPayable    Float
  totalPaid       Float             @default(0)
  status          String            @default("PENDING")
  issueDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  member          Member            @relation(fields: [memberId], references: [id], map: "Loan_memberId_fkey")
  loanInstallment LoanInstallment[]
  voucher         Voucher[]

  @@index([memberId], map: "Loan_memberId_fkey")
  @@map("loan")
}

model LoanInstallment {
  id        String   @id @default(cuid())
  loanId    String
  amount    Float
  date      DateTime @default(now())
  status    String   @default("PAID")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  loan      Loan     @relation(fields: [loanId], references: [id], map: "LoanInstallment_loanId_fkey")

  @@index([loanId], map: "LoanInstallment_loanId_fkey")
  @@map("loaninstallment")
}

model Member {
  id                    String                  @id @default(cuid())
  memberId              String                  @unique(map: "Member_memberId_key")
  name                  String
  phone                 String                 
  email                 String?
  nid                   String?
  address               String?
  type                  String                  @default("General")
  position              String                  @default("Member")
  status                String                  @default("ACTIVE")
  joinDate              DateTime                @default(now())
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  photo                 String?
  loan                  Loan[]
  monthlySavingsSummary MonthlySavingsSummary[]
  savingsAccount       SavingsAccount[]
  voucher               Voucher[]

  @@map("member")
}

model MemberType {
  id        String   @id @default(cuid())
  name      String   @unique(map: "MemberType_name_key")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("membertype")
}

model MonthlySavingsSummary {
  id        String   @id @default(cuid())
  memberId  String
  year      Int
  jan       Float    @default(0)
  feb       Float    @default(0)
  mar       Float    @default(0)
  apr       Float    @default(0)
  may       Float    @default(0)
  jun       Float    @default(0)
  jul       Float    @default(0)
  aug       Float    @default(0)
  sep       Float    @default(0)
  oct       Float    @default(0)
  nov       Float    @default(0)
  dec       Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  member    Member   @relation(fields: [memberId], references: [id], map: "MonthlySavingsSummary_memberId_fkey")

  @@unique([memberId, year], map: "MonthlySavingsSummary_memberId_year_key")
  @@map("monthlysavingssummary")
}

model Position {
  id        String   @id @default(cuid())
  name      String   @unique(map: "Position_name_key")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("position")
}

model SavingsAccount {
  id                 String               @id @default(cuid())
  accountNo          String               @unique(map: "SavingsAccount_accountNo_key")
  memberId           String
  type               String
  balance            Float                @default(0)
  interestRate       Float                @default(0)
  status             String               @default("ACTIVE")
  openDate           DateTime             @default(now())
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  member             Member               @relation(fields: [memberId], references: [id], map: "SavingsAccount_memberId_fkey")
  transactions       SavingsTransaction[]
  voucher           Voucher[]

  @@index([memberId], map: "SavingsAccount_memberId_fkey")
  @@map("savingsaccount")
}

model SavingsTransaction {
  id               String         @id @default(cuid())
  savingsAccountId String
  type             String
  amount           Float
  date             DateTime       @default(now())
  reference        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  depositMonth     String?
  remarks          String?
  transactionDate  DateTime?
  voucherNo        String?
  savingsAccount   SavingsAccount @relation(fields: [savingsAccountId], references: [id], map: "SavingsTransaction_savingsAccountId_fkey")

  @@index([savingsAccountId], map: "SavingsTransaction_savingsAccountId_fkey")
  @@map("savingstransaction")
}

model User {
  id          String        @id @default(cuid())
  name        String
  email       String        @unique(map: "User_email_key")
  password    String
  role        String        @default("STAFF")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  activityLog ActivityLog[]

  @@map("user")
}

model Voucher {
  id               String          @id @default(cuid())
  voucherNo        String
  type             String
  category         String
  amount           Float
  description      String?
  date             DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  loanId           String?
  memberId         String?
  savingsAccountId String?
  depositMonth     String?
  loan             Loan?           @relation(fields: [loanId], references: [id], map: "Voucher_loanId_fkey")
  member           Member?         @relation(fields: [memberId], references: [id], map: "Voucher_memberId_fkey")
  savingsAccount   SavingsAccount? @relation(fields: [savingsAccountId], references: [id], map: "Voucher_savingsAccountId_fkey")

  @@index([loanId], map: "Voucher_loanId_fkey")
  @@index([memberId], map: "Voucher_memberId_fkey")
  @@index([savingsAccountId], map: "Voucher_savingsAccountId_fkey")
  @@map("voucher")
}

model AccountCategory {
  id        String   @id @default(cuid())
  name      String   @unique(map: "accountcategory_name_idx")
  type      String   @default("INCOME") // INCOME, EXPENSE, INVESTMENT
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("accountcategory")
}
